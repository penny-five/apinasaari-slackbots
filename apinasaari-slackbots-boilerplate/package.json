{
  "name": "@apinasaari-slackbots/boilerplate",
  "version": "1.0.0",
  "description": "Slackbot boilerplate",
  "main": "index.js",
  "author": "penny-five",
  "license": "MIT",
  "private": true,
  "dependencies": {
    "@apinasaari-slackbots/common": "1.0.0",
    "pino": "6.7.0"
  },
  "devDependencies": {
    "concurrently": "5.3.0",
    "env-cmd": "10.1.0",
    "nodemon": "2.0.6",
    "rimraf": "3.0.2",
    "ts-loader": "8.0.4",
    "typescript": "4.0.3",
    "webpack": "4.44.2",
    "webpack-cli": "3.3.12",
    "webpack-node-externals": "2.5.2"
  },
  "scripts": {
    "build": "rimraf dist/**/* && webpack",
    "serve": "nodemon --watch dist --exec \"env-cmd --silent functions-framework --source=dist --target default\"",
    "dev": "NODE_ENV=development concurrently \"yarn build --watch\" \"yarn serve\""
  }
}

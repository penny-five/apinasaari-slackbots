{
  "private": true,
  "workspaces": [
    "apinasaari-slackbots-*"
  ],
  "devDependencies": {
    "husky": "4.3.0",
    "lint-staged": "10.4.0",
    "prettier": "2.1.2"
  },
  "scripts": {
    "tf-fmt": "fmt () { for f in $*; do terraform fmt $f; done }; fmt"
  },
  "husky": {
    "hooks": {
      "pre-commit": "lint-staged"
    }
  },
  "lint-staged": {
    "*.ts": [
      "prettier --write"
    ],
    "*.{js,md,json}": [
      "prettier --write"
    ],
    "*.tf": [
      "yarn tf-fmt"
    ]
  }
}
